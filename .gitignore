# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env*
!.env.example
# Instagram scrape artifacts (not for production)
/public/dimitra.html
/public/dimitra2.html
/public/dimitra3.html
/public/dimitra_files/
/public/dimitra2_files/
/public/dimitra3_files/

# local database (contact submissions & dynamic resources)
/data/

# uploaded files (local dev only; production uses Netlify Blobs)
/public/uploads/resources/*
!/public/uploads/resources/.gitkeep

# vercel
.vercel

# netlify
.netlify

# typescript
*.tsbuildinfo
next-env.d.ts
