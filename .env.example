# Netlify → Site configuration → Environment variables
# Never commit real values — copy this file to .env.local only on your machine.

# Admin login (server-only — not exposed to the browser)
ADMIN_EMAIL=ask@thepoumaacademy.com
ADMIN_PASSWORD=your-secure-password-here
ADMIN_SESSION_SECRET=generate-a-long-random-string-min-32-chars

# Production domain — SEO, sitemap, link previews (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
